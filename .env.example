# kuhik-core — Production Environment
# Copy to .env and fill with real values
# docker-compose reads this file automatically

# === DATABASE ===
# If using the built-in postgres service:
POSTGRES_PASSWORD=change-this-to-a-strong-password
DATABASE_URL=postgresql://kuhik:${POSTGRES_PASSWORD}@postgres:5432/kuhik

# If using external PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/kuhik

# === JWT (REQUIRED — must be strong random strings) ===
JWT_SECRET=<generate-a-random-64-char-string>
JWT_REFRESH_SECRET=<generate-another-random-64-char-string>

# === CORS ===
# Frontend domain (must match where users will access the app)
CORS_ORIGINS=https://app.example.com

# === FRONTEND ===
# Public API URL (must match the above domain + /api prefix)
NEXT_PUBLIC_API_URL=https://app.example.com

# === OPTIONAL ===
# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Redis (optional — queues disabled if not set)
# REDIS_URL=redis://user:password@host:6379

# Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# S3_BUCKET=my-bucket
# S3_REGION=eu-north-1