{
  "name": "kuhik-core",
  "version": "1.0.0",
  "private": true,
  "description": "Kuhik — Korteriühistute haldussüsteem",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "db:generate": "cd backend && npx prisma generate",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:push": "cd backend && npx prisma db push",
    "db:studio": "cd backend && npx prisma studio",
    "db:seed": "cd backend && npm run db:seed",
    "db:reset": "cd backend && npm run db:reset",
    "db:seed:full": "cd backend && npm run db:seed:full",
    "db:seed:winter": "cd backend && npm run db:seed:winter",
    "db:seed:tenant-change": "cd backend && npm run db:seed:tenant-change",
    "db:seed:late-payments": "cd backend && npm run db:seed:late-payments",
    "db:seed:high-consumption": "cd backend && npm run db:seed:high-consumption",
    "test": "cd backend && npm test",
    "typecheck": "cd backend && npx tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}