# kuhik-core — Production Environment Configuration
# Copy to .env and fill with real values

# Mandatory — system will fail to start if missing
DATABASE_URL=postgresql://user:password@host:5432/kuhik
JWT_SECRET=<generate-a-random-64-char-string>
JWT_REFRESH_SECRET=<generate-another-random-64-char-string>

# Server
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# CORS — must include your frontend domain(s)
CORS_ORIGINS=https://app.example.com

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Redis (optional — queues disabled if not set)
# REDIS_URL=redis://user:password@host:6379

# Storage (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# S3_BUCKET=my-bucket
# S3_REGION=eu-north-1
# S3_ENDPOINT=https://s3.eu-north-1.amazonaws.com