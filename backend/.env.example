# Database
DATABASE_URL=postgresql://kuhik:kuhik_secret@localhost:5432/kuhik

# Redis (optional — queues disabled if not set)
REDIS_URL=redis://localhost:6379

# JWT secrets
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-secret

# Server
PORT=4000
HOST=0.0.0.0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3456

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Storage (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads