  summaryHash     String?  @map("summary_hash")
  totalReceivables Float   @default(0) @map("total_receivables")
  totalPayments   Float    @default(0) @map("total_payments")
  totalOutstanding Float   @default(0) @map("total_outstanding")
  totalPenalties  Float    @default(0) @map("total_penalties")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  period  AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([periodId])
  @@map("period_closes")
}

/// BudgetLine — planned vs actual per category per period.
model BudgetLine {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  periodId        String   @map("period_id")
  costCategoryId  String   @map("cost_category_id")
  plannedAmount   Float    @default(0) @map("planned_amount")
  actualAmount    Float    @default(0) @map("actual_amount")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period      AccountingPeriod @relation(fields: [periodId], references: [id])
  costCategory CostCategory  @relation(fields: [costCategoryId], references: [id])

  @@unique([periodId, costCategoryId])
  @@map("budget_lines")
}

/// ReserveFund — tracks reserve accumulation per period.
model ReserveFund {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  periodId        String   @map("period_id")
  costCategoryId  String?  @map("cost_category_id")
  targetAmount    Float    @default(0) @map("target_amount")
  collectedAmount Float    @default(0) @map("collected_amount")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period      AccountingPeriod @relation(fields: [periodId], references: [id])
  costCategory CostCategory?   @relation(fields: [costCategoryId], references: [id])

  @@unique([periodId, costCategoryId])
  @@map("reserve_funds")
}

// ============================================================
// WAVE D.2 — DOUBLE-ENTRY BOOKKEEPING (Journal Entry)
// ============================================================

/// JournalEntry — header for a double-entry journal entry.
/// INVARIANT: total_debit === total_credit always.
model JournalEntry {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  periodId     String?  @map("period_id")
  entryDate    DateTime @default(now()) @map("entry_date")
  referenceType String  @map("reference_type")  // invoice | payment | expense | manual
  referenceId  String?  @map("reference_id")
  description  String?  @db.Text
  totalDebit   Float    @default(0) @map("total_debit")
  totalCredit  Float    @default(0) @map("total_credit")
  status       String   @default("posted")      // draft | posted | reversed
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period AccountingPeriod?  @relation(fields: [periodId], references: [id])
  lines  JournalEntryLine[]

  @@index([tenantId, periodId])
  @@index([referenceType, referenceId])
  @@map("journal_entries")
}

/// JournalEntryLine — individual debit/credit line in a journal entry.
/// INVARIANT: For each line, either debit_amount > 0 XOR credit_amount > 0.
model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String   @map("journal_entry_id")
  tenantId       String   @map("tenant_id")
  accountId      String   @map("account_id")
  debitAmount    Float    @default(0) @map("debit_amount")
  creditAmount   Float    @default(0) @map("credit_amount")
  description    String?  @db.Text
  costCategoryId String?  @map("cost_category_id")
  apartmentId    String?  @map("apartment_id")
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account      ChartAccount  @relation(fields: [accountId], references: [id])
  costCategory CostCategory? @relation(fields: [costCategoryId], references: [id])
  apartment    Apartment?    @relation(fields: [apartmentId], references: [id])

  @@index([accountId, tenantId])
  @@index([journalEntryId])
  @@map("journal_entry_lines")
}

/// FinancialSnapshot — immutable frozen state of system at period close.
model FinancialSnapshot {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  periodId          String   @map("period_id")
  snapshotData      Json     @map("snapshot_data") // full frozen state
  totalReceivables  Float    @default(0) @map("total_receivables")
  totalPayments     Float    @default(0) @map("total_payments")
  totalOutstanding  Float    @default(0) @map("total_outstanding")
  totalPenalties    Float    @default(0) @map("total_penalties")
  reserveBalance    Float    @default(0) @map("reserve_balance")
  integrityHash     String?  @map("integrity_hash")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period AccountingPeriod @relation(fields: [periodId], references: [id])

  @@unique([periodId])
  @@map("financial_snapshots")
}

