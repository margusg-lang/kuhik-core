generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH (NextAuth v5 / Auth.js)
// ============================================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// WAVE A — FINANCIAL CLASSIFICATION
// ============================================================
model AccountClass {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  statementType String @default("unknown") @map("statement_type")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts ChartAccount[]
  @@unique([tenantId, code])
  @@map("account_classes")
}

model CashflowGroup {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  direction String   @default("inflow")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts ChartAccount[]
  @@unique([tenantId, code])
  @@map("cashflow_groups")
}

model CostCategory {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  kind      String   @default("both")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  costs             Cost[]
  allocationItems   AllocationItem[]
  allocationShares  AllocationShare[]
  chartAccounts     ChartAccount[]      @relation("DefaultCostCategory")
  chargeLines       ChargeLine[]
  allocationRules   AllocationRule[]    @relation("RuleDefaultCategory")
  allocationRunCosts AllocationRunCost[]
  receivables       Receivable[]
  budgetLines       BudgetLine[]
  reserveFunds      ReserveFund[]
  journalEntryLines JournalEntryLine[]

  @@unique([tenantId, code])
  @@map("cost_categories")
}

model ChartAccount {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  accountNumber       String   @map("account_number")
  name                String
  accountClassId      String   @map("account_class_id")
  cashflowGroupId     String?  @map("cashflow_group_id")
  defaultCostCategoryId String? @map("default_cost_category_id")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountClass      AccountClass  @relation(fields: [accountClassId], references: [id])
  cashflowGroup     CashflowGroup? @relation(fields: [cashflowGroupId], references: [id])
  defaultCostCategory CostCategory? @relation("DefaultCostCategory", fields: [defaultCostCategoryId], references: [id])
  journalEntryLines JournalEntryLine[]

  @@unique([tenantId, accountNumber])
  @@map("chart_accounts")
}

// ============================================================
// MULTI-TENANT CORE
// ============================================================

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  registryCode String?  @map("registry_code")
  address      String?
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  isActive     Boolean  @default(true) @map("is_active")
  settings     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users                  TenantUser[]
  buildings              Building[]
  apartments             Apartment[]
  residents              Resident[]
  people                 Person[]
  apartmentPeople        ApartmentPerson[]
  resourceTypes          ResourceType[]
  meters                 Meter[]
  meterReadings          MeterReading[]
  events                 Event[]
  issues                 Issue[]
  allocationRules        AllocationRule[]
  costs                  Cost[]
  costAllocations        CostAllocation[]
  invoices               Invoice[]
  invoiceLines           InvoiceLine[]
  payments               Payment[]
  bankTransactions       BankTransaction[]
  ownershipHistories     OwnershipHistory[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  cronJobs               CronJob[]
  meritSyncRecords       MeritSyncRecord[]
  apartmentMeters        ApartmentMeter[]
  apartmentMeterReadings ApartmentMeterReading[]
  utilityCosts           UtilityCost[]
  allocationRuns         AllocationRun[]
  kuhikInvoices          KuhikInvoice[]
  accountClasses         AccountClass[]
  cashflowGroups         CashflowGroup[]
  costCategories         CostCategory[]
  chartAccounts          ChartAccount[]
  chargeLines            ChargeLine[]
  allocationShares       AllocationShare[]
  receivables            Receivable[]
  penaltyEntries         PenaltyEntry[]
  paymentAllocations     PaymentAllocation[]
  accountingPeriods      AccountingPeriod[]
  periodCloses           PeriodClose[]
  budgetLines            BudgetLine[]
  reserveFunds           ReserveFund[]
  financialSnapshots     FinancialSnapshot[]
  journalEntries         JournalEntry[]
  journalEntryLines      JournalEntryLine[]

  @@map("tenants")
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String   @default("resident")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  tenants   TenantUser[]
  auditLogs AuditLog[]
  @@map("users")
}

// ============================================================
// BUILDING & APARTMENT
// ============================================================

model Building {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  type      String   @default("apartment_building")
  address   String?
  metadata  Json?    @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartments    Apartment[]
  resourceTypes ResourceType[]
  meters        Meter[]
  issues        Issue[]
  @@map("buildings")
}

model Apartment {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  buildingId        String   @map("building_id")
  unitLabel         String   @map("unit_label")
  floor             Int?
  areaSqm           Float?   @map("area_sqm")
  heatedAreaSqm     Float?   @map("heated_area_sqm")
  calculatedAreaSqm Float?   @map("calculated_area_sqm")
  occupancy         Int      @default(1)
  ownershipShare    Float?   @map("ownership_share")
  metadata          Json?    @default("{}")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building           Building           @relation(fields: [buildingId], references: [id])
  residents          Resident[]
  people             ApartmentPerson[]
  meters             Meter[]
  meterReadings      MeterReading[]
  costAllocations    CostAllocation[]
  invoices           Invoice[]
  invoiceLines       InvoiceLine[]
  issues             Issue[]
  ownershipHistories OwnershipHistory[]
  apartmentMeters    ApartmentMeter[]
  allocationItems    AllocationItem[]
  kuhikInvoices      KuhikInvoice[]
  chargeLines        ChargeLine[]
  allocationShares   AllocationShare[]
  receivables        Receivable[]
  penaltyEntries     PenaltyEntry[]
  paymentAllocations PaymentAllocation[]
  payments           Payment[]
  journalEntryLines  JournalEntryLine[]

  @@unique([buildingId, unitLabel])
  @@map("apartments")
}

// ============================================================
// PEOPLE, METERS, UTILITY COSTS
// ============================================================

model Person {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  fullName     String   @map("full_name")
  email        String?
  phone        String?
  personalCode String?  @map("personal_code")
  notes        String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartments ApartmentPerson[]
  @@index([tenantId])
  @@map("people")
}

model ApartmentPerson {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  apartmentId      String    @map("apartment_id")
  personId         String    @map("person_id")
  relationshipType String    @default("RESIDENT") @map("relationship_type")
  isPrimary        Boolean   @default(false) @map("is_primary")
  validFrom        DateTime? @map("valid_from")
  validTo          DateTime? @map("valid_to")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartment Apartment @relation(fields: [apartmentId], references: [id])
  person    Person    @relation(fields: [personId], references: [id])
  @@unique([apartmentId, personId, relationshipType])
  @@index([personId])
  @@map("apartment_people")
}

model ApartmentMeter {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  apartmentId  String   @map("apartment_id")
  meterType    String   @map("meter_type")
  unit         String   @default("m3")
  serialNumber String?  @map("serial_number")
  label        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartment Apartment               @relation(fields: [apartmentId], references: [id])
  readings  ApartmentMeterReading[]
  @@index([apartmentId])
  @@map("apartment_meters")
}

model ApartmentMeterReading {
  id        String   @id @default(cuid())
  meterId   String   @map("meter_id")
  tenantId  String   @map("tenant_id")
  value     Float    @default(0)
  timestamp DateTime @default(now())
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")

  meter  ApartmentMeter @relation(fields: [meterId], references: [id], onDelete: Cascade)
  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([meterId, timestamp])
  @@map("apartment_meter_readings")
}

model UtilityCost {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  type         String   @default("other")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  totalAmount  Float    @map("total_amount")
  currency     String   @default("EUR")
  supplierName String?  @map("supplier_name")
  description  String?  @db.Text
  source       String   @default("manual")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId, periodStart])
  @@map("utility_costs")
}

// ============================================================
// WAVE B — ALLOCATION TRACEABILITY CORE
// ============================================================

model AllocationRule {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  buildingId     String?  @map("building_id")
  resourceTypeId String?  @map("resource_type_id")
  name           String
  method         String   @default("equal")
  targetScope    String   @default("building") @map("target_scope")
  defaultCostCategoryId String? @map("default_cost_category_id")
  params         Json?    @default("{}")
  priority       Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resourceType    ResourceType?    @relation(fields: [resourceTypeId], references: [id])
  defaultCostCategory CostCategory? @relation("RuleDefaultCategory", fields: [defaultCostCategoryId], references: [id])
  costs           Cost[]
  allocationRuns  AllocationRun[]
  @@map("allocation_rules")
}

model AllocationRun {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  buildingId      String?  @map("building_id")
  allocationRuleId String? @map("allocation_rule_id")
  periodYear      Int?     @map("period_year")
  periodMonth     Int?     @map("period_month")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  status          String   @default("draft")
  totalSourceAmount Float  @default(0) @map("total_source_amount")
  totalAllocatedAmount Float @default(0) @map("total_allocated_amount")
  roundingMethod  String   @default("round_half_up") @map("rounding_method")
  roundingRemainder Float @default(0) @map("rounding_remainder")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  finalizedAt     DateTime? @map("finalized_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  allocationRule  AllocationRule?  @relation(fields: [allocationRuleId], references: [id])
  items           AllocationItem[]
  sourceCosts     AllocationRunCost[]
  chargeLines     ChargeLine[]
  kuhikInvoices   KuhikInvoice[]
  @@index([tenantId, periodYear, periodMonth])
  @@map("allocation_runs")
}

model AllocationRunCost {
  id              String   @id @default(cuid())
  runId           String   @map("run_id")
  costId          String   @map("cost_id")
  costCategoryId  String?  @map("cost_category_id")
  sourceAmount    Float    @default(0) @map("source_amount")
  createdAt       DateTime @default(now()) @map("created_at")

  run           AllocationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  cost          Cost          @relation(fields: [costId], references: [id])
  costCategory  CostCategory? @relation(fields: [costCategoryId], references: [id])
  @@index([runId])
  @@index([costId])
  @@map("allocation_run_costs")
}

model AllocationItem {
  id             String   @id @default(cuid())
  runId          String   @map("run_id")
  apartmentId    String   @map("apartment_id")
  costType       String   @map("cost_type")
  costCategoryId String?  @map("cost_category_id")
  method         String   @default("equal")
  amount         Float    @default(0)
  basisValue     Float?   @map("basis_value")
  basisTotal     Float?   @map("basis_total")
  consumptionPct Float?   @map("consumption_pct")
  createdAt      DateTime @default(now()) @map("created_at")

  run          AllocationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  apartment    Apartment      @relation(fields: [apartmentId], references: [id])
  costCategory CostCategory?  @relation(fields: [costCategoryId], references: [id])
  chargeLines  ChargeLine[]
  @@index([runId])
  @@index([apartmentId])
  @@map("allocation_items")
}

// ============================================================
// WAVE B.5 — ALLOCATION SHARE (per-apartment-per-cost-type mapping)
// ============================================================

/// AllocationShare — explicit mapping of how each apartment
/// participates in each cost type's allocation.
/// This is the "Osalused" table from Korto.
/// INVARIANT: share_value is always positive (m², count, or ratio).
model AllocationShare {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  costCategoryId String @map("cost_category_id")
  apartmentId  String   @map("apartment_id")
  periodId     String?  @map("period_id")      // null = permanent default share

  shareValue   Decimal  @map("share_value")     // m², 1/N, or explicit ratio
  unit         String   @default("m²")          // m², krt, m³, kWh, %

  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  costCategory CostCategory @relation(fields: [costCategoryId], references: [id])
  apartment    Apartment    @relation(fields: [apartmentId], references: [id])

  @@unique([costCategoryId, apartmentId, periodId])
  @@index([tenantId, costCategoryId])
  @@index([apartmentId])
  @@map("allocation_shares")
}

model ChargeLine {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  apartmentId     String    @map("apartment_id")
  allocationRunId String?   @map("allocation_run_id")
  allocationItemId String?  @map("allocation_item_id")
  costCategoryId  String?   @map("cost_category_id")
  label           String
  amount          Float     @default(0)
  sourceType      String    @default("allocation")
  status          String    @default("active")
  periodYear      Int?      @map("period_year")
  periodMonth     Int?      @map("period_month")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartment       Apartment     @relation(fields: [apartmentId], references: [id])
  allocationRun   AllocationRun? @relation(fields: [allocationRunId], references: [id])
  allocationItem  AllocationItem? @relation(fields: [allocationItemId], references: [id])
  costCategory    CostCategory?  @relation(fields: [costCategoryId], references: [id])
  invoiceLines    InvoiceLine[]
  kuhikInvoiceItems KuhikInvoiceItem[]
  receivables     Receivable[]
  @@index([tenantId, apartmentId])
  @@index([allocationRunId])
  @@index([status])
  @@map("charge_lines")
}

// ============================================================
// WAVE C — FINANCIAL STATE LAYER
// ============================================================

model Receivable {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  apartmentId       String    @map("apartment_id")
  chargeLineId      String?   @map("charge_line_id")
  costCategoryId    String?   @map("cost_category_id")
  sourceType        String    @default("charge")
  sourceReferenceId String?   @map("source_reference_id")
  amountOriginal    Float     @default(0) @map("amount_original")
  amountOutstanding Float     @default(0) @map("amount_outstanding")
  amountPaid        Float     @default(0) @map("amount_paid")
  status            String    @default("open")
  periodYear        Int?      @map("period_year")
  periodMonth       Int?      @map("period_month")
  dueDate           DateTime? @map("due_date")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartment         Apartment          @relation(fields: [apartmentId], references: [id])
  chargeLine        ChargeLine?        @relation(fields: [chargeLineId], references: [id])
  costCategory      CostCategory?      @relation(fields: [costCategoryId], references: [id])
  paymentAllocations PaymentAllocation[]
  penaltyEntries    PenaltyEntry[]     @relation("PenaltySourceReceivable")
  @@index([tenantId, apartmentId])
  @@index([tenantId, status])
  @@index([chargeLineId])
  @@map("receivables")
}

model Payment {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  apartmentId       String?   @map("apartment_id")
  invoiceId         String?   @map("invoice_id")
  amount            Float     @default(0)
  paymentDate       DateTime  @map("payment_date")
  referenceNumber   String?   @map("reference_number")
  method            String    @default("bank_transfer")
  allocationState   String    @default("unallocated")
  bankTransactionId String?   @map("bank_transaction_id")
  status            String    @default("received")
  metadata          Json?     @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartment       Apartment?       @relation(fields: [apartmentId], references: [id])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  allocations     PaymentAllocation[]
  @@index([tenantId, apartmentId])
  @@index([referenceNumber])
  @@map("payments")
}

model PaymentAllocation {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  paymentId       String   @map("payment_id")
  receivableId    String   @map("receivable_id")
  apartmentId     String?  @map("apartment_id")
  amountAllocated Float    @default(0) @map("amount_allocated")
  method          String   @default("fifo")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment    Payment    @relation(fields: [paymentId], references: [id])
  receivable Receivable @relation(fields: [receivableId], references: [id])
  apartment  Apartment? @relation(fields: [apartmentId], references: [id])
  @@index([paymentId])
  @@index([receivableId])
  @@unique([paymentId, receivableId])
  @@map("payment_allocations")
}

model PenaltyEntry {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  apartmentId     String    @map("apartment_id")
  sourceReceivableId String? @map("source_receivable_id")
  ruleId          String?   @map("rule_id")
  amount          Float     @default(0)
  interestRate    Float?    @map("interest_rate")
  daysOverdue     Int?      @map("days_overdue")
  periodYear      Int?      @map("period_year")
  periodMonth     Int?      @map("period_month")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartment       Apartment  @relation(fields: [apartmentId], references: [id])
  sourceReceivable Receivable? @relation("PenaltySourceReceivable", fields: [sourceReceivableId], references: [id])
  @@index([tenantId, apartmentId])
  @@index([sourceReceivableId])
  @@index([periodYear, periodMonth])
  @@map("penalty_entries")
}

// ============================================================
// WAVE D — ACCOUNTING CONTROL LAYER
// ============================================================

/// AccountingPeriod — financial time window.
/// Governs when billing, payments, and modifications are allowed.
model AccountingPeriod {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  periodYear  Int      @map("period_year")
  periodMonth Int      @map("period_month")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  status      String   @default("open") // open | finalizing | closed | locked
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  close       PeriodClose?
  budgets     BudgetLine[]
  reserves    ReserveFund[]
  snapshots   FinancialSnapshot[]
  journalEntries JournalEntry[]

  @@unique([tenantId, periodYear, periodMonth])
  @@index([tenantId, status])
  @@map("accounting_periods")
}

/// PeriodClose — snapshot of the period closure event.
model PeriodClose {
  id              String   @id @default(cuid())
  periodId        String   @map("period_id")
  tenantId        String   @map("tenant_id")
  closedAt        DateTime @default(now()) @map("closed_at")
