# kuhik-core — Staging Environment Configuration
# Copy to .env and fill with real values

DATABASE_URL=postgresql://user:password@staging-host:5432/kuhik
JWT_SECRET=<generate-a-random-64-char-string>
JWT_REFRESH_SECRET=<generate-another-random-64-char-string>

NODE_ENV=staging
PORT=4000
HOST=0.0.0.0

CORS_ORIGINS=https://staging.example.com

RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

STORAGE_TYPE=local
UPLOAD_DIR=./uploads