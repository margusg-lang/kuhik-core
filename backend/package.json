{
  "name": "kuhik-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:reset": "tsx prisma/seed/reset.ts",
    "db:seed:full": "tsx prisma/seed/index.ts --mode=full",
    "db:seed:winter": "tsx prisma/seed/index.ts --mode=scenario:winter-billing",
    "db:seed:tenant-change": "tsx prisma/seed/index.ts --mode=scenario:tenant-change",
    "db:seed:late-payments": "tsx prisma/seed/index.ts --mode=scenario:late-payments",
    "db:seed:high-consumption": "tsx prisma/seed/index.ts --mode=scenario:high-consumption",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "reconcile": "tsx scripts/financial-reconciliation-runner.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.20.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.25.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
